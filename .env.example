# ── App ──────────────────────────────────────────────────────────
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
DEBUG=false
SERVER_HOST=0.0.0.0
SERVER_PORT=8000

# ── Database ──────────────────────────────────────────────────────
POSTGRES_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql://lp:change-me-strong-password@db:5432/lpmonitor

# ── Admin bootstrap ───────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_EMAIL=giuseppe@defranceschi.pro
ADMIN_PASSWORD=change-me-strong-password

# ── Discogs ───────────────────────────────────────────────────────
# Get from https://www.discogs.com/settings/developers
DISCOGS_TOKEN=
DISCOGS_USER_AGENT=LPMonitor/1.0 +https://vinylmonitor.dffm.it

# ── Claude AI (optional) ──────────────────────────────────────────
CLAUDE_API_KEY=
CLAUDE_ENABLED=true
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=1024
CLAUDE_TIMEOUT_SECONDS=30

# ── Email / SMTP ──────────────────────────────────────────────────
# Gmail: enable 2FA, generate App Password at myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=giuseppe@defranceschi.pro
SMTP_PASS=your-gmail-app-password
SMTP_FROM=LP Monitor <giuseppe@defranceschi.pro>
MAIL_TO=giuseppe@defranceschi.pro
EMAIL_ENABLED=true

# ── Scheduler ─────────────────────────────────────────────────────
SCAN_INTERVAL_MINUTES=60
